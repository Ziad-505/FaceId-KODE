# ── HTTP ──
PORT=4000
# Comma-separated list of allowed origins for CORS (the frontend dev + prod URLs)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ──
# Either set DATABASE_URL, or the discrete PG* vars below.
DATABASE_URL=postgresql://kode:kode@localhost:5432/kode_faceid
# PGHOST=localhost
# PGPORT=5432
# PGUSER=ziad
# PGPASSWORD=ziad123
# PGDATABASE=kode_faceid

# ── Logging ──
# error | warn | info | debug — structured JSON logs to stdout for monitoring
LOG_LEVEL=info

# ── Auth ──
# Use a long random string in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-48
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ── Seed (first admin, created by `npm run seed`) ──
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=kode@2026!
SEED_ADMIN_FULLNAME=Administrator
SEED_CX_USERNAME=cxteam
SEED_CX_PASSWORD=cxteam@26
SEED_CX_FULLNAME=CX Team
